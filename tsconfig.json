{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*", "env.d.ts"],
	"exclude": ["dist"],
  	"compilerOptions": {
      "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ],
    "baseUrl": ".",
		"paths": {
			"@components/*": ["src/components/*"],
			"@data/*": ["src/data/*"],
			"@imgs/*": ["src/assets/imgs/*"],
			"@videos/*": ["src/assets/videos/*"],
			"@fonts/*": ["src/assets/fonts/*"]
		},
		"jsx": "react-jsx",
		"jsxImportSource": "react"
	}
}
