---
import Layout from "@layouts/Layout.astro";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { PROJECTS } from "@data/projects";

const projectsData = PROJECTS.map((p) => ({
  place: p.place,
  title: p.title,
  img: p.img.src,
}));
---

<Layout>
  <section
    class="flex flex-col items-start justify-center gap-4 w-full min-h-screen px-[10%] py-24 bg-white"
  >
    <div class="flex flex-col gap-2">
      <h1 class="flex flex-col gap-2 text-5xl md:text-6xl font-black">
        <span class="text-[#004ea9]">PROYECTOS</span>
        <span>SOLARES</span>
      </h1>
      <p class="text-gray-600 text-lg max-w-2xl">
        Conoce nuestros proyectos destacados de energía solar en Guatemala.
        Sistemas instalados por profesionales certificados.
      </p>
    </div>

    <ul
      id="projects-grid"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-4 w-full"
    >
      {
        PROJECTS.slice(0, 4).map((project) => (
          <li class="project-card group relative transition-all duration-500 hover:scale-102">
            <Image
              src={project.img}
              alt={project.description}
              class={"w-full h-64 object-cover rounded-lg"}
            />

            <div class="absolute bottom-0 left-0 right-0 bg-black/25 backdrop-blur-sm px-4 py-3 text-white rounded-b-lg">
              <p class="text-sm text-gray-300 flex items-center gap-1">
                <Icon name="lucide:map-pin" class="w-4 h-4" />
                {project.place}
              </p>
              <h3 class="font-bold text-lg">{project.title}</h3>
            </div>
          </li>
        ))
      }
    </ul>

    <button
      id="load-more-btn"
      class="flex items-center gap-2 px-6 py-3 border-2 border-[#004ea9] text-[#004ea9] font-bold rounded-lg transition-all duration-300 hover:bg-[#004ea9] hover:text-white self-center"
    >
      <Icon name="lucide:plus" class="w-5 h-5" />
      <span>Ver más proyectos</span>
    </button>
  </section>

  <div
    class="flex flex-col items-center justify-center gap-4 w-full py-8 bg-[#004ea9] text-white text-center"
  >
    <h2 class="text-6xl font-black">¿Tienes un proyecto en mente?</h2>
    <p class="text-white/80 text-xl w-1/2">
      Contacta con nuestro equipo de expertos para recibir asesoramiento
      personalizado y un presupuesto detallado para tu proyecto solar.
    </p>
    <a
      href="/productos-solares"
      class="group flex items-center justify-start gap-2 hover:underline w-fit py-2 rounded-md text-xl font-semibold"
    >
      <span>Contáctanos</span>
      <Icon
        name="lucide:arrow-right"
        class="group-hover:translate-x-2 transition-all duration-500"
      />
    </a>
  </div>
</Layout>

<script define:vars={{ projectsData }}>
  const projects = projectsData;
  let visibleCount = 4;
  const batchSize = 4;

  const grid = document.getElementById("projects-grid");
  const btn = document.getElementById("load-more-btn");

  btn.addEventListener("click", () => {
    const nextProjects = projects.slice(visibleCount, visibleCount + batchSize);

    nextProjects.forEach((project) => {
      const li = document.createElement("li");
      li.className =
        "project-card group relative transition-all duration-500 hover:scale-102";
      li.innerHTML = `
        <img src="${project.img}" alt="${project.title}" class="w-full h-64 object-cover rounded-lg" />
        <div class="absolute bottom-0 left-0 right-0 bg-black/25 backdrop-blur-sm px-4 py-3 text-white rounded-b-lg">
          <p class="text-sm text-gray-300 flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            ${project.place}
          </p>
          <h3 class="font-bold text-lg">${project.title}</h3>
        </div>
      `;
      grid.appendChild(li);
    });

    visibleCount += nextProjects.length;

    if (visibleCount >= projects.length) {
      btn.style.display = "none";
    }
  });
</script>
