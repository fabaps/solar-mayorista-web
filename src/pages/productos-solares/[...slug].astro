---
import { Icon } from "astro-icon/components";
import Layout from "../../layouts/Layout.astro";
import { PRODUCTS_ITEMS } from "@data/products-items";

export function getStaticPaths() {
  return PRODUCTS_ITEMS.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;

const whatsappMsg = `Hola, estoy interesado en el producto: ${product.Nombre}. ¿Podrían brindarme más información?`;
const whatsappUrl = `https://api.whatsapp.com/send/?phone=50230916300&text=${encodeURIComponent(whatsappMsg)}&type=phone_number&app_absent=0`;
---

<Layout>
  <section
    class="bg-[#004ea9] text-white flex flex-col items-start justify-start gap-2 py-24 px-[10%]"
  >
    <a
      href="/productos-solares"
      class="mb-2 flex items-center gap-1 text-lg text-gray-200 hover:underline"
    >
      <Icon name="lucide:arrow-left" />
      Volver a productos
    </a>
    <h1 class="text-4xl lg:text-5xl font-black">{product.Nombre}</h1>
    {
      product.Marca && (
        <span class="rounded-full bg-white/20 px-4 py-1 text-sm font-semibold">
          {product.Marca}
        </span>
      )
    }
  </section>

  <section class="grid grid-cols-1 gap-8 px-[10%] py-12 lg:grid-cols-2">
    <div class="flex items-center justify-center rounded-lg bg-gray-50 p-8">
      <img
        src={product.Imagen}
        alt={product.Nombre}
        class="h-auto max-h-[500px] w-full object-contain"
      />
    </div>

    <div class="flex flex-col gap-6">
      <div>
        <span class="text-sm font-semibold text-gray-500">Categoría</span>
        <p class="text-xl font-bold text-gray-900">{product.Categoria}</p>
      </div>

      {
        product.Marca && (
          <div>
            <span class="text-sm font-semibold text-gray-500">Marca</span>
            <p class="text-xl font-bold text-gray-900">{product.Marca}</p>
          </div>
        )
      }

      <div>
        <span class="text-sm font-semibold text-gray-500">Descripción</span>
        <p
          class="mt-1 whitespace-pre-line text-base leading-relaxed text-gray-700"
        >
          {product.Descripcion}
        </p>
      </div>

      <div
        class="flex flex-wrap items-center gap-3 border border-black/25 p-4 rounded-md"
      >
        {
          product.FichaTecnica && (
            <a
              href={product.FichaTecnica}
              target="_blank"
              rel="noopener noreferrer"
              class="flex w-full items-center gap-2 rounded-md border border-[#004fa8] text-[#004fa8] px-6 py-3 font-semibold transition-colors hover:bg-blue-700 hover:text-white"
            >
              <Icon name="lucide:file-text" />
              Descargar ficha técnica
            </a>
          )
        }
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex w-full items-center gap-2 rounded-md border border-green-600 px-6 py-3 font-semibold text-green-600 hover:bg-green-600 hover:text-white"
        >
          <Icon name="mdi:whatsapp" />
          Consultar por WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>
