---
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout>
  <div
    class="relative w-full h-[calc(100vh-80px)] flex flex-col items-center justify-center bg-[#0050a7] text-white overflow-hidden"
  >
    <div
      class="relative z-10 flex flex-col items-center gap-8 text-center px-4"
    >
      <div class="flex items-center justify-center">
        <span class="text-[12rem] leading-none font-bold"> 404 </span>
      </div>

      <div class="flex flex-col gap-2">
        <h1 class="text-3xl md:text-4xl font-bold">Página No Encontrada</h1>
        <p class="text-lg text-white/80 max-w-md">
          Lo sentimos, la página que buscas no existe o ha sido movida.
        </p>
      </div>

      <a
        href="/"
        class="flex items-center gap-2 px-6 py-3 bg-[#0d57ad] border border-white/50 font-bold rounded-lg hover:underline"
      >
        <Icon name="lucide:home" class="text-2xl" />
        <span>Volver al Inicio</span>
      </a>
    </div>
  </div>
</Layout>

