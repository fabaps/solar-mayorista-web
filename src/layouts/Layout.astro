---
import "../styles/global.css";
import Navbar from "@components/layout/Navbar.astro";
import Footer from "@components/layout/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = "Mayorista Solar Guatemala | Red de Asesores Fotovoltaicos",
  description = "Red de asesores fotovoltaicos en Guatemala. Ingeniería especializada, capacitación, acompañamiento técnico, equipos certificados y financiamiento para impulsar tus proyectos solares.",
  keywords = "paneles solares, inversores solares, baterías solares, energía solar Guatemala, distribuidora solar, instaladores solares, ingeniería solar, proyectos solares, equipos solares, mayorista solar",
  image = "/og-image.jpeg",
  noindex = false,
} = Astro.props as Props;
---

<!doctype html>
<html lang="es" class="font-inter">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/png"
      href="/favicon-96x96.png?v=20260622"
      sizes="96x96"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260622" />
    <link rel="shortcut icon" href="/favicon.ico?v=20260622" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-touch-icon.png?v=20260622"
    />
    <meta name="apple-mobile-web-app-title" content="Mayorista Solar" />
    <link rel="manifest" href="/site.webmanifest?v=20260622" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mayorista Solar Guatemala" />
    <meta
      property="og:logo"
      content={new URL("/favicon.svg", Astro.url).href}
    />
    <meta property="og:locale" content="es_GT" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url).href} />
    <meta property="og:url" content={Astro.url.href} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.url).href} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <script>
      import "@scripts/parallaxImage.ts";
    </script>
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
