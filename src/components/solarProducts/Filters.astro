---
import { PRODUCTS_ITEMS } from "@data/products-items";

const categories = [...new Set(PRODUCTS_ITEMS.map((p) => p.Categoria))];
const brands = [
  ...new Set(
    PRODUCTS_ITEMS.map((p) => p.Marca).filter((b): b is string => b !== null),
  ),
];
---

<div class="flex flex-wrap items-center gap-4 px-[10%] py-6">
  <input
    type="search"
    id="search-input"
    placeholder="Buscar productos por nombre…"
    class="min-w-[200px] flex-1 rounded-md border border-gray-300 px-4 py-2 text-sm focus:border-[#004fa8] focus:outline-none"
  />
  <select
    id="category-select"
    class="rounded-md border border-gray-300 px-4 py-2 text-sm focus:border-[#004fa8] focus:outline-none"
  >
    <option value="">Todas las categorías</option>
    {categories.map((cat) => <option value={cat}>{cat}</option>)}
  </select>
  <select
    id="brand-select"
    class="rounded-md border border-gray-300 px-4 py-2 text-sm focus:border-[#004fa8] focus:outline-none"
  >
    <option value="">Todas las marcas</option>
    {brands.map((brand) => <option value={brand}>{brand}</option>)}
  </select>
</div>
