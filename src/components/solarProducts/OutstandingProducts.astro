---
import { PRODUCTS_ITEMS } from "@data/products-items";
---

<section
  class="flex flex-col items-start justify-center gap-2 px-[5%] w-full mt-6 lg:mt-12"
>
  <div
    class="bg-gray-200 flex flex-col items-start justify-center gap-4 p-6 w-full rounded-lg"
  >
    <h2 class="flex flex-col text-4xl lg:text-6xl font-black uppercase">
      <span class="gradient-blue">Productos</span>
      <span class="text-gray-900">Destacados</span>
    </h2>

    <div
      class="flex flex-row lg:grid lg:grid-cols-3 gap-2 lg:gap-4 w-full max-w-full overflow-x-auto"
    >
      {
        PRODUCTS_ITEMS.filter((p) => p.isOutstanding)
          .slice(0, 9)
          .map((product) => (
            <a
              href={`/productos-solares/${product.id}`}
              class="flex flex-col overflow-hidden rounded-lg border border-gray-200 bg-white min-w-11/12 w-11/12 lg:min-w-full lg:w-full"
            >
              <div class="flex h-46 items-center justify-center overflow-hidden bg-gray-50 p-4">
                <img
                  src={product.Imagen}
                  alt={product.Nombre}
                  class="h-full w-full object-contain"
                  loading="lazy"
                />
              </div>

              <div class="flex flex-1 flex-col justify-between gap-2 p-4">
                <div class="flex items-start justify-between gap-2">
                  <h3 class="text-lg font-bold text-gray-900">
                    {product.Nombre}
                  </h3>
                </div>

                {product.Marca && (
                  <span class="w-fit rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-[#004fa8]">
                    {product.Marca}
                  </span>
                )}

                <p class="line-clamp-3 text-sm leading-relaxed text-gray-600">
                  {product.Descripcion}
                </p>

                <div class="bg-[#004fa8] text-white px-2 py-1 rounded-md text-center">
                  Ver Detalles
                </div>
              </div>
            </a>
          ))
      }
    </div>
  </div>
</section>
