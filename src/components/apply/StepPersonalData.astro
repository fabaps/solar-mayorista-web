<div data-step="1" class="step-section flex flex-col gap-4">
  <div class="bg-white rounded-xl shadow-sm border border-black/5 p-6 flex flex-col gap-5">
    <div class="flex flex-col gap-1">
      <label for="name" class="font-semibold text-sm text-gray-800">Nombre completo</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        placeholder="Tu nombre"
        class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-800 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#004ea9] focus:border-transparent transition-all duration-200"
      />
    </div>

    <div class="flex flex-col gap-1">
      <label for="email" class="font-semibold text-sm text-gray-800">Correo electrónico</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="tu@correo.com"
        class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-800 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#004ea9] focus:border-transparent transition-all duration-200"
      />
    </div>

    <div class="flex flex-col gap-1">
      <label for="phone" class="font-semibold text-sm text-gray-800">Teléfono</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        required
        placeholder="(+502) 1234 5678"
        class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-800 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#004ea9] focus:border-transparent transition-all duration-200"
      />
    </div>
  </div>
</div>
