---
import { Icon } from "astro-icon/components";
import StepPersonalData from "./StepPersonalData.astro";
import StepPreQuote from "./StepPreQuote.astro";
import StepCommercialProgress from "./StepCommercialProgress.astro";

const STEPS = [
  { number: 1, label: "Datos personales" },
  { number: 2, label: "Pre cotiza" },
  { number: 3, label: "Avance comercial" },
];
---

<section class="bg-gray-100 flex flex-col w-full min-h-screen">
  <div class="flex flex-col items-center w-full">
    <div class="bg-[#004ea9] w-full px-[10%] pt-24 pb-6 mb-4">
      <h1 class="text-4xl lg:text-6xl font-black text-center mb-2 text-white">
        <span>Aplica</span>
      </h1>
      <p class="text-md lg:text-xl text-center text-gray-100 mb-6">
        Si tu proyecto aplica serás contactado por nuestro departamento de
        ingeniería
      </p>

      <div
        class="flex flex-col lg:flex-row items-center justify-center gap-2 lg:gap-6 text-gray-100 text-sm lg:text-lg"
      >
        <span>¿Te falta experiencia?</span>
        <a
          href="https://adepenlinea.com/"
          class="group flex items-center justify-start gap-2 bg-white text-[#004ea9] hover:underline w-fit px-5 py-1 rounded-md"
        >
          <span>Capacitate en sistemas Fotovoltaicos</span>
          <Icon
            name="lucide:arrow-right"
            class="group-hover:translate-x-2 transition-all duration-500"
          />
        </a>
      </div>
    </div>

    <!-- Step indicators -->
    <div class="flex items-center justify-center gap-3 w-full mb-6 px-4">
      {
        STEPS.map((step, i) => (
          <>
            <div class="flex items-center gap-2">
              <div
                class="step-indicator flex items-center justify-center w-11 h-11 rounded-full text-base font-bold transition-all duration-300 bg-gray-300 text-gray-500"
                data-step={step.number}
              >
                <span class="step-number">{step.number}</span>
                <Icon name="lucide:check" class="step-check hidden text-xl" />
              </div>
              <span
                class="step-label hidden sm:block text-sm font-medium transition-all duration-300 text-gray-400"
                data-step={step.number}
              >
                {step.label}
              </span>
            </div>
            {i < STEPS.length - 1 && (
              <div
                class="step-line flex-1 h-1 max-w-16 rounded transition-all duration-300 bg-gray-300"
                data-step={step.number}
              />
            )}
          </>
        ))
      }
    </div>

    <form
      id="aplica-form"
      novalidate
      class="flex flex-col gap-4 w-full px-[5%] lg:px-[10%]"
    >
      <StepPersonalData />
      <StepPreQuote />
      <StepCommercialProgress />

      <!-- Navigation buttons -->
      <div class="flex items-center justify-between gap-4 mb-2">
        <button
          type="button"
          id="prev-btn"
          class="hidden flex items-center justify-center gap-2 border border-[#004ea9] text-[#004ea9] font-semibold px-6 py-3 rounded-md transition-all duration-300 hover:bg-[#004ea9] hover:text-white"
        >
          <Icon name="lucide:arrow-left" class="text-lg" />
          <span>Anterior</span>
        </button>

        <div class="flex-1"></div>

        <button
          type="button"
          id="next-btn"
          class="flex items-center justify-center gap-2 bg-[#004ea9] text-white font-semibold px-6 py-3 rounded-md transition-all duration-300 hover:bg-[#003d8a]"
        >
          <span>Siguiente</span>
          <Icon name="lucide:arrow-right" class="text-lg" />
        </button>

        <button
          type="submit"
          id="submit-btn"
          class="hidden flex items-center justify-center gap-2 bg-[#004ea9] text-white font-semibold px-6 py-3 rounded-md transition-all duration-300 hover:bg-[#003d8a]"
        >
          <Icon name="lucide:mail" class="text-xl" />
          <span>Enviar por correo</span>
        </button>
      </div>

      <div
        id="form-status"
        class="hidden text-center text-sm font-semibold px-4 py-3 mt-2"
      >
        Solicitud enviada con éxito.
      </div>
    </form>
  </div>
</section>

<script>
  const FUNCTION_URL =
    "https://us-central1-adep-bfc12.cloudfunctions.net/mayoristaSolarApplicationToJoin";

  const form = document.getElementById("aplica-form");
  const steps = document.querySelectorAll(".step-section");
  const stepIndicators = document.querySelectorAll(".step-indicator");
  const stepNumbers = document.querySelectorAll(".step-number");
  const stepChecks = document.querySelectorAll(".step-check");
  const stepLabels = document.querySelectorAll(".step-label");
  const stepLines = document.querySelectorAll(".step-line");
  const prevBtn = document.getElementById("prev-btn");
  const nextBtn = document.getElementById("next-btn");
  const submitBtn = document.getElementById("submit-btn");
  const formStatus = document.getElementById("form-status");
  let currentStep = 1;
  const totalSteps = 3;

  function setStatus(type, message) {
    formStatus.classList.remove(
      "hidden",
      "bg-[#004fa833]",
      "text-blue-700",
      "bg-red-100",
      "text-red-700",
    );
    formStatus.classList.add(
      type === "success" ? "bg-[#004fa833]" : "bg-red-100",
      type === "success" ? "text-[#004fa8]" : "text-red-700",
    );
    formStatus.textContent = message;
  }

  function updateStepUI() {
    steps.forEach((el) => {
      const step = Number(el.dataset.step);
      if (step === currentStep) {
        el.classList.remove("hidden");
      } else {
        el.classList.add("hidden");
      }
    });

    stepIndicators.forEach((el) => {
      const step = Number(el.dataset.step);
      el.classList.remove(
        "bg-[#004ea9]",
        "text-white",
        "bg-gray-300",
        "text-gray-500",
      );
      if (step <= currentStep) {
        el.classList.add("bg-[#004ea9]", "text-white");
      } else {
        el.classList.add("bg-gray-300", "text-gray-500");
      }
    });

    stepNumbers.forEach((el) => {
      const step = Number(el.closest("[data-step]")?.dataset.step);
      el.classList.toggle("hidden", step < currentStep);
    });

    stepChecks.forEach((el) => {
      const step = Number(el.closest("[data-step]")?.dataset.step);
      el.classList.toggle("hidden", step >= currentStep);
    });

    stepLabels.forEach((el) => {
      const step = Number(el.dataset.step);
      el.classList.remove("text-[#004ea9]", "text-gray-600", "text-gray-400");
      if (step <= currentStep) {
        el.classList.add("text-gray-600");
      } else {
        el.classList.add("text-gray-400");
      }
    });

    stepLines.forEach((el) => {
      const step = Number(el.dataset.step);
      el.classList.remove("bg-[#004ea9]", "bg-gray-300");
      if (step < currentStep) {
        el.classList.add("bg-[#004ea9]");
      } else {
        el.classList.add("bg-gray-300");
      }
    });

    prevBtn.classList.toggle("hidden", currentStep === 1);

    if (currentStep === totalSteps) {
      nextBtn.classList.add("hidden");
      submitBtn.classList.remove("hidden");
    } else {
      nextBtn.classList.remove("hidden");
      submitBtn.classList.add("hidden");
    }
  }

  function validateStep(step) {
    const stepEl = document.querySelector(`[data-step="${step}"]`);
    const requiredFields = stepEl.querySelectorAll("[required]");
    let valid = true;

    requiredFields.forEach((field) => {
      field.classList.remove("border-red-500");
      if (!field.value || field.value === "") {
        field.classList.add("border-red-500");
        valid = false;
      }
      if (field.tagName === "SELECT" && field.value === "") {
        field.classList.add("border-red-500");
        valid = false;
      }
    });

    return valid;
  }

  nextBtn?.addEventListener("click", () => {
    if (!validateStep(currentStep)) return;
    if (currentStep < totalSteps) {
      currentStep++;
      updateStepUI();
    }
  });

  prevBtn?.addEventListener("click", () => {
    if (currentStep > 1) {
      currentStep--;
      updateStepUI();
    }
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    formStatus.classList.add("hidden");

    if (!validateStep(currentStep)) return;

    const fd = new FormData(form);
    const payload = {
      name: fd.get("name")?.toString().trim() || "",
      email: fd.get("email")?.toString().trim() || "",
      phone: fd.get("phone")?.toString().trim() || "",
      projectType: fd.get("project-type")?.toString().trim() || "",
      location: fd.get("location")?.toString().trim() || "",
      solutionType: fd.get("solution-type")?.toString().trim() || "",
      clientWants: fd.get("client-wants")?.toString().trim() || "",
      commercialStatus: fd.get("commercial-status")?.toString().trim() || "",
      budget: fd.get("budget")?.toString().trim() || "",
      workedBefore: fd.get("worked-before")?.toString().trim() || "",
      whoContacted: fd.get("who-contacted")?.toString().trim() || "",
      hasQuotes: fd.get("has-quotes")?.toString().trim() || "",
      knowsInvestment: fd.get("knows-investment")?.toString().trim() || "",
      paymentMethod: fd.get("payment-method")?.toString().trim() || "",
      doneSolarProject: fd.get("done-solar-project")?.toString().trim() || "",
    };

    submitBtn.disabled = true;
    submitBtn.innerHTML = "Enviando...";

    try {
      const res = await fetch(FUNCTION_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      if (!res.ok) {
        const err = await res.text();
        throw new Error(err);
      }

      setStatus("success", "Solicitud enviada con éxito.");
      form.reset();
      currentStep = 1;
      updateStepUI();
    } catch (err) {
      setStatus("error", "Error al enviar la solicitud. Intenta de nuevo.");
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = "Enviar por correo";
    }
  });

  updateStepUI();
</script>
