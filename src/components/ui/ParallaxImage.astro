---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  class?: string;
  speed?: number;
}

const { src, alt, class: className = "", speed = 0.3 } = Astro.props;
---

<div class="overflow-hidden">
  <Image
    src={src}
    alt={alt}
    class={`parallax ${className}`}
    data-speed={speed}
  />
</div>

<script>
  const elements = document.querySelectorAll(".parallax");

  if (elements.length) {
    let ticking = false;

    const update = () => {
      elements.forEach((el) => {
        const speed = Number(el.dataset.speed ?? 0.3);
        el.style.transform = `translateY(${window.scrollY * speed}px)`;
      });

      ticking = false;
    };

    window.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(update);
      },
      { passive: true },
    );
  }
</script>
