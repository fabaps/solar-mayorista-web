---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import { NAVBAR_ITEMS } from "@data/navbar";

import MayoristaSolarLogo from "@imgs/logos/mayorista-solar.png";
---

<nav
  id="navbar"
  class="bg-black/50 backdrop-blur-xl text-white fixed top-0 left-0 w-full flex flex-row items-center justify-between gap-2 px-[10%] py-2 transition-all duration-500 z-99"
  aria-label="Navegación principal"
>
  <a
    href="/"
    class="flex flex-row gap-2 items-center justify-center w-fit transition-all duration-500 ease-out hover:bg-white/15 px-3 py-1 rounded-md"
  >
    <Image
      src={MayoristaSolarLogo}
      alt={"Mayorista solar logo"}
      class={"w-8 h-8 object-cover bg-white p-1 rounded-full"}
    />

    <div class="flex flex-col items-start justify-center">
      <span class="font-bold">Mayorista Solar</span>
      <span class="text-sm hidden sm:block">Red de Asesores Fotovoltaicos</span>
    </div>
  </a>

  <ul
    class="hidden lg:flex flex-row gap-2 items-center justify-center list-none m-0 p-0"
  >
    {
      NAVBAR_ITEMS.map((navbarItem) => (
        <li>
          <a
            href={navbarItem.url}
            class="transition-all duration-500 ease-out hover:bg-white/15 rounded-md px-2 py-1 text-bold"
          >
            {navbarItem.name}
          </a>
        </li>
      ))
    }
  </ul>

  <button
    id="menu-toggle"
    class="lg:hidden flex items-center justify-center p-2 rounded-md hover:bg-white/15 transition-all duration-300"
    aria-label="Abrir menú"
    aria-controls="mobile-menu"
    aria-expanded="false"
  >
    <Icon name="lucide:menu" class="w-6 h-6" id="menu-icon" />
  </button>
</nav>

<div
  id="mobile-menu"
  class="fixed top-0 left-0 w-full h-full bg-black/80 backdrop-blur-2xl z-100 flex flex-col items-center justify-center transition-all duration-500 opacity-0 pointer-events-none"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación"
>
  <!-- Top bar -->
  <div
    class="absolute top-0 left-0 w-full flex items-center justify-between px-[10%] py-4"
  >
    <a
      href="/"
      class="mobile-link flex items-center gap-2 transition-all duration-300 hover:opacity-80"
    >
      <Image
        src={MayoristaSolarLogo}
        alt="Mayorista solar logo"
        class="w-8 h-8 object-cover bg-white p-1 rounded-full"
      />
      <span class="font-bold text-sm text-white">Mayorista Solar</span>
    </a>
    <button
      id="menu-close"
      class="p-2 text-white rounded-xl hover:bg-white/10 active:bg-white/20 transition-all duration-300"
      aria-label="Cerrar menú"
    >
      <Icon name="lucide:x" class="w-7 h-7" />
    </button>
  </div>

  <!-- Spacer -->
  <div class="flex-1"></div>

  <!-- Nav links -->
  <ul class="flex flex-col items-stretch justify-center gap-3 w-full px-[5%]">
    {
      NAVBAR_ITEMS.map((navbarItem) => (
        <li>
          <a
            href={navbarItem.url}
            class="mobile-link block text-center w-full text-xl font-bold text-white/90 py-4 px-6 rounded-2xl border border-white/10 hover:bg-white/10 active:bg-white/15 hover:border-white/20 transition-all duration-300"
          >
            {navbarItem.name}
          </a>
        </li>
      ))
    }
  </ul>

  <!-- Bottom CTA -->
  <div class="w-full px-[5%] mt-8 mb-12">
    <a
      href="/aplica"
      class="mobile-link block w-full text-center bg-[#004ea9] hover:bg-[#003d8a] active:bg-[#002d6a] text-white font-bold py-4 px-6 rounded-2xl transition-all duration-300"
    >
      Aplica con tu proyecto
    </a>
  </div>
</div>

<script is:inline>
  const navbar = document.getElementById("navbar");
  const menuToggle = document.getElementById("menu-toggle");
  const menuClose = document.getElementById("menu-close");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const mobileLinks = document.querySelectorAll(".mobile-link");
  let lastScroll = 0;

  function openMenu() {
    mobileMenu.classList.remove("opacity-0", "pointer-events-none");
    mobileMenu.classList.add("opacity-100", "pointer-events-auto");
    menuToggle.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
    mobileMenu.classList.add("opacity-0", "pointer-events-none");
    menuToggle.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  menuToggle.addEventListener("click", openMenu);
  menuClose.addEventListener("click", closeMenu);

  mobileLinks.forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  const updateNavbar = () => {
    const currentScroll = window.scrollY;

    if (currentScroll > 200 && currentScroll > lastScroll) {
      navbar.style.transform = "translateY(-100%)";
    } else {
      navbar.style.transform = "translateY(0)";
    }

    lastScroll = currentScroll;
  };

  window.addEventListener("scroll", updateNavbar);
  updateNavbar();
</script>
