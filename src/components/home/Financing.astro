---
import { Image } from "astro:assets";
import { FINANCING_CARDS } from "@data/financing";
---

<section
  id="financiamiento"
  class="bg-gray-100 flex flex-col items-start justify-center gap-2 w-full lg:h-screen min-h-auto lg:min-h-auto px-[5%] py-12 lg:py-[5%]"
>
  <header class="flex items-start justify-between gap-2 w-full">
    <h2 class="flex flex-col gap-2 text-4xl lg:text-6xl font-black uppercase">
      <span class="text-[#004ea9]">Financia</span>
      <span class="text-gray-900">tu proyecto</span>
    </h2>
  </header>

  <p class="w-full lg:w-3/4 text-sm lg:text-xl mb-6">
    Accede a nuestra infraestructura financiera diseñada para impulsar el
    crecimiento de tu negocio:
  </p>

  <ul class="grid grid-cols-1 lg:grid-cols-4 gap-4 w-full list-none">
    {
      FINANCING_CARDS.map((card) => (
        <li>
          <article class="flex flex-col bg-white rounded-xl p-5 border border-black/5 shadow-[0_4px_12px_-6px_rgba(0,0,0,0.08)] [transform:perspective(600px)_rotateX(2deg)] transition-all duration-400 hover:-translate-y-1.5 hover:shadow-[0_12px_30px_-10px_rgba(0,78,169,0.2)] hover:[transform:perspective(600px)_rotateX(0deg)]">
            <header class="flex items-center gap-2 border-b border-gray-100 pb-3">
              <Image
                src={card.logo.src}
                alt={card.logo.alt}
                class="h-8 w-auto object-contain"
              />
              <h3 class="font-bold text-sm uppercase tracking-wide text-gray-900 leading-tight">
                {card.title}
              </h3>
            </header>
            <p class="text-xs text-gray-500 mt-2">{card.subtitle}</p>
          </article>
        </li>
      ))
    }
  </ul>

  <a
    href="/aplica"
    class="group flex items-center gap-2 mt-6 py-3 rounded-md hover:underline"
  >
    <span>Aplica con tu proyecto</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-4 w-4 group-hover:translate-x-2 transition-all duration-500"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <path d="M5 12h14M12 5l7 7-7 7"></path>
    </svg>
  </a>
</section>
