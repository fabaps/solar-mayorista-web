---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { SPECIALIZED_ENGINEERING } from "@data/specializedEngineering";
---

<section
  id="ingenieria-especializada"
  class="relative text-gray-700 bg-gray-200 grid grid-cols-1 lg:grid-cols-2 items-center justify-center gap-2 w-full h-screen px-[10%] z-10"
>
  <div>
    <h1 class="text-4xl lg:text-6xl font-black">
      <span class="text-gray-900">INGENIERIA</span>
      <span class="text-[#004ea9]">ESPECIALIZADA</span>
    </h1>
    <p class="text-sm lg:text-sm">Lista de comprobación para levantamiento de datos / Visita tecnica</p>

    <div class="flex flex-row lg:flex-col lg:items-center lg:justify-center gap-2 w-full min-w-full overflow-x-auto my-4">
      {
      SPECIALIZED_ENGINEERING.map((specializedEngineering, index) => (
        <>
        <div
          class="hidden group first:z-2 lg:flex items-center justify-between bg-white/5 border border-gray-400 hover:bg-white/15 text-start w-full pl-4 pr-8 py-4 min-h-full hover:z-3 cursor-pointer lg:cursor-default"
        >
            {specializedEngineering.title}
            <Icon
              name="lucide:chevrons-right"
              class="group-hover:translate-x-2 transition-all duration-500"
            />

            <!-- Modal -->
            <article class="hidden lg:flex absolute top-0 left-0 w-full h-full invisible text-white">
              <div
                class="absolute flex flex-col items-center justify-center p-4 top-1/2 right-[10%] -translate-y-1/2 gap-2 w-1/3 h-4/6 h-auto text-4xl transition-all duration-300 ease-in bg-[#0d57ad] border border-[#0d57ad11] group-hover:scale-105 invisible group-hover:visible"
              >
                <div class="flex flex-row items-center justify-center w-full">
                  <Image
                    src={specializedEngineering.img}
                    alt={specializedEngineering.alt}
                    class={"w-full lg:h-56 2xl:h-64 object-cover"}
                  />
                </div>
                <div class="flex flex-col gap-1 w-full h-full items-center justify-start">
                  <span class="text-lg font-bold text-white">{specializedEngineering.title}</span>
                  <div class="flex flex-col gap-2 text-sm lg:text-xs 2xl:text-sm text-gray-100 overflow-y-auto">
                    {
                      specializedEngineering.description.map((block) =>
                        typeof block === "string" ? (
                          <p>{block}</p>
                        ) : (
                          <ul class="list-disc list-inside">
                            {block.map((item) => <li>{item}</li>)}
                          </ul>
                        )
                      )
                    }
                  </div>
                </div>
              </div>
            </article>
          </div>

          <div
            class="lg:hidden flex flex-col items-center gap-3 bg-[#0d57ad] text-white min-w-64 border border-white/15 rounded-b-lg p-4 transition-all duration-300"
            data-card={index}
          >
            <Image
              src={specializedEngineering.img}
              alt={specializedEngineering.alt}
              class="w-full h-48 object-cover rounded-md"
            />
            <span class="text-xl font-bold">{specializedEngineering.title}</span>
            <div class="flex flex-col gap-2 text-sm text-pretty max-h-32 overflow-y-auto">
              {
                specializedEngineering.description.map((block) =>
                  typeof block === "string" ? (
                    <p>{block}</p>
                  ) : (
                    <ul class="list-disc list-inside">
                      {block.map((item) => <li>{item}</li>)}
                    </ul>
                  )
                )
              }
            </div>
          </div>
        </>
        ))
      }
    </div>

    <a
      href="/aplica"
      class="group flex items-center justify-start gap-2 hover:underline w-fit py-2 rounded-md"
    >
      <span>Aplica con tu proyecto</span>
      <Icon
        name="lucide:arrow-right"
        class="group-hover:translate-x-2 transition-all duration-500"
      />
    </a>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll("#ingenieria-especializada .engineering-btn");
  const cards = document.querySelectorAll("#ingenieria-especializada .mobile-card");

  function isMobile() {
    return window.innerWidth < 1024;
  }

  buttons.forEach((btn, i) => {
    btn.addEventListener("click", () => {
      if (!isMobile()) return;

      const currentCard = cards[i];
      const isOpen = !currentCard.classList.contains("hidden");

      cards.forEach((c) => c.classList.add("hidden"));
      buttons.forEach((b) => b.classList.remove("rounded-b-lg"));

      if (!isOpen) {
        currentCard.classList.remove("hidden");
        btn.classList.add("rounded-b-none");
      }
    });
  });
</script>

<style>
@keyframes rotate-card {
  0% {
    opacity: 0;
    transform: translateX(10%);
  }
  50% {
    transform: translateX(100%);
  }
  100% {
    opacity: 1;
    transform: translateX(50%);
  }
}

.animate-rotate-card {
  animation: rotate-card 5s ease-out;
}
</style>
