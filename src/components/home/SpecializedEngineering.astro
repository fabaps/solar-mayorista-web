---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { SPECIALIZED_ENGINEERING } from "@data/specializedEngineering";
---

<section
  id="specialized-engineering"
  class="relative text-white bg-[#004daa] grid grid-cols-1 lg:grid-cols-2 items-center justify-center gap-2 w-full h-screen text-black px-[10%]"
>
  <div>
    <h1 class="text-6xl font-black">
      <span>INGENIERIA</span>
      <span class="text-[#ffd600]">ESPECIALIZADA</span>
    </h1>
    <h2 class="text-xl">
      ¿Cuál es el proyecto que te está pidiendo tu cliente?
    </h2>
    <p>Nosotros te apoyamos en el proceso.</p>

    <div class="flex flex-col items-center justify-center gap-2 w-full my-4">
      {
        SPECIALIZED_ENGINEERING.map((specializedEngineering) => (
          <div class="group flex items-center justify-between bg-white/5 border border-white/15 text-start w-full pl-4 pr-8 py-4 min-h-full">
            {specializedEngineering.title}
            <Icon
              name="lucide:chevrons-right"
              class="group-hover:translate-x-2 transition-all duration-500"
            />

            <!-- Modal -->
            <div class="group absolute top-0 left-0 w-full h-full invisible">
              <div class="absolute flex flex-col items-center justify-center invisible group-hover:visible top-1/2 right-[10%] -translate-y-1/2 flex flex-col gap-4 p-2 w-1/3 h-4/5  text-4xl rounded-lg">
                <div class="flex flex-row items-center justify-center w-full transition-all duration-400 -translate-x-[-100%] group-hover:translate-x-0 opacity-0 group-hover:opacity-100">
                  <Image
                    src={specializedEngineering.img}
                    alt={specializedEngineering.description}
                    width={200}
                    height={64}
                    class={"w-auto h-64 object-cover"}
                  />
                </div>
                <div class="flex w-full h-full items-center justify-center transition-all duration-500 -translate-x-[-100%] group-hover:translate-x-0 opacity-0 group-hover:opacity-100">
                  <p class="text-xl">{specializedEngineering.description}</p>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <a
      href="/productos-solares"
      class="group flex items-center justify-start gap-2 hover:underline bg-white/15 w-fit px-5 py-2"
    >
      <Icon name="mdi:whatsapp" class="text-xl text-green-200" />
      <span>Consultar a equio técnico</span>
      <Icon
        name="lucide:arrow-right"
        class="group-hover:translate-x-2 transition-all duration-500"
      />
    </a>
  </div>
</section>
