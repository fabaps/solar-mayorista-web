---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { SPECIALIZED_ENGINEERING } from "@data/specializedEngineering";
---

<section
  id="ingenieria-especializada"
  class="relative text-white bg-[#004daa] grid grid-cols-1 lg:grid-cols-2 items-center justify-center gap-2 w-full h-screen text-black px-[10%] z-10"
>
  <div>
    <h1 class="text-4xl lg:text-6xl font-black">
      <span>INGENIERIA</span>
      <span class="text-[#ffd600]">ESPECIALIZADA</span>
    </h1>
    <h2 class="text-xl">
      ¿Cuál es el proyecto que te está pidiendo tu cliente?
    </h2>
    <p>Nosotros te apoyamos en el proceso.</p>

    <div class="flex flex-col items-center justify-center gap-2 w-full my-4">
      {
      SPECIALIZED_ENGINEERING.map((specializedEngineering, index) => (
        <>
        <div
          class="engineering-btn group first:z-2 flex items-center justify-between bg-white/5 border border-white/15 hover:bg-white/25 text-start w-full pl-4 pr-8 py-4 min-h-full hover:z-3 cursor-pointer lg:cursor-default"
        >
            {specializedEngineering.title}
            <Icon
              name="lucide:chevrons-right"
              class="group-hover:translate-x-2 transition-all duration-500"
            />

            <!-- Modal -->
            <article class="hidden lg:flex absolute top-0 left-0 w-full h-full invisible">
              <div
                class="absolute flex flex-col items-center justify-center visible top-1/2 right-[10%] -translate-y-1/2 gap-2 p-2 w-1/3 h-4/6 max-h-4/6 text-4xl transition-all duration-300 ease-out bg-[#0d57ad] border border-white/15 px-3 py-2 group-hover:scale-105"
              >
                <div class="flex flex-row items-center justify-center w-full">
                  <Image
                    src={specializedEngineering.img}
                    alt={specializedEngineering.description}
                    class={"w-full h-64 object-cover rounded-md"}
                  />
                </div>
                <div class="flex flex-col gap-2 w-full h-full items-center justify-start">
                  <span class="text-xl font-bold">{specializedEngineering.title}</span>
                  <p class="text-lg text-wrap truncate">{specializedEngineering.description}</p>
                </div>
              </div>
            </article>
          </div>

          <div
            class="lg:hidden mobile-card hidden flex-col items-center gap-3 bg-[#0d57ad] border border-white/15 rounded-b-lg p-4 transition-all duration-300"
            data-card={index}
          >
            <Image
              src={specializedEngineering.img}
              alt={specializedEngineering.description}
              class="w-full h-48 object-cover rounded-md"
            />
            <span class="text-xl font-bold">{specializedEngineering.title}</span>
            <p class="text-base text-pretty">{specializedEngineering.description}</p>
          </div>
        </>
        ))
      }
    </div>

    <a
      href="/productos-solares"
      class="group flex items-center justify-start gap-2 hover:underline w-fit py-2 rounded-md"
    >
      <Icon name="mdi:whatsapp" class="text-xl text-green-400" />
      <span>Consultar a equio técnico</span>
      <Icon
        name="lucide:arrow-right"
        class="group-hover:translate-x-2 transition-all duration-500"
      />
    </a>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll("#ingenieria-especializada .engineering-btn");
  const cards = document.querySelectorAll("#ingenieria-especializada .mobile-card");

  function isMobile() {
    return window.innerWidth < 1024;
  }

  buttons.forEach((btn, i) => {
    btn.addEventListener("click", () => {
      if (!isMobile()) return;

      const currentCard = cards[i];
      const isOpen = !currentCard.classList.contains("hidden");

      cards.forEach((c) => c.classList.add("hidden"));
      buttons.forEach((b) => b.classList.remove("rounded-b-lg"));

      if (!isOpen) {
        currentCard.classList.remove("hidden");
        btn.classList.add("rounded-b-none");
      }
    });
  });
</script>

<style>
@keyframes rotate-card {
  0% {
    opacity: 0;
    transform: translateX(10%);
  }
  50% {
    transform: translateX(100%);
  }
  100% {
    opacity: 1;
    transform: translateX(50%);
  }
}

.animate-rotate-card {
  animation: rotate-card 5s ease-out;
}
</style>
