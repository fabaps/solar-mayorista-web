---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { PROJECTS } from "@data/projects";
---

<section
  class="bg-gray-100 flex flex-col items-start justify-start gap-2 w-full min-h-screen px-[10%] py-12 lg:py-[5%]"
>
  <div
    class="flex flex-col lg:flex-row items-start lg:items-end justify-between gap-4 lg:gap-0 w-full mb-4"
  >
    <h1 class="flex flex-col gap-2 text-4xl lg:text-6xl font-black uppercase">
      <span class="text-[#004ea9]">Historias</span>
      <span class="text-gray-900">Destacadas</span>
    </h1>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 w-full mt-4">
    {
      PROJECTS.map((project) => (
        <div class="group flex flex-col bg-white text-white rounded-xl overflow-hidden border border-black/5 transition-all duration-300 hover:-translate-y-1">
          <!-- Image grid: first image takes full width, next two side by side -->
          <div class="grid grid-cols-2">
            <Image
              src={project.images[0].src}
              alt={project.images[0].alt}
              class="col-span-2 w-full h-48 object-cover"
            />
            <Image
              src={project.images[1].src}
              alt={project.images[1].alt}
              class="w-full h-24 object-cover"
            />
            <Image
              src={project.images[2].src}
              alt={project.images[2].alt}
              class="w-full h-24 object-cover"
            />
          </div>

          <div class="flex flex-col gap-1 px-5 py-4 bg-[#004ea9] min-h-full">
            <span class="font-bold text-md">{project.title}</span>
            <span class="text-sm">{project.name}</span>
          </div>
        </div>
      ))
    }
  </div>
</section>
