---
import { Image } from "astro:assets";
import { PROJECTS } from "@data/projects";
---

<section
  id="proyectos"
  class="bg-gray-100 flex flex-col items-start justify-start gap-2 w-full min-h-screen px-[5%] py-12 lg:py-[5%]"
>
  <header class="flex flex-col lg:flex-row items-start lg:items-end justify-between gap-4 lg:gap-0 w-full mb-4">
    <h2 class="flex flex-col gap-2 text-4xl lg:text-6xl font-black uppercase">
      <span class="gradient-blue">Historias</span>
      <span class="text-gray-900">Destacadas</span>
    </h2>
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 w-full mt-4">
    {
      PROJECTS.map((project, i) => (
        <article class="group relative flex flex-col bg-white rounded-2xl overflow-hidden border border-black/5 transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_60px_-10px_rgba(0,78,169,0.3)]">
          <!-- Main image -->
          <figure class="relative overflow-hidden">
            <Image
              src={project.images[0].src}
              alt={project.images[0].alt}
              class="w-full h-56 object-cover transition-all duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent" />
            <figcaption class="absolute bottom-4 left-4 right-4 flex items-center justify-between">
              <h3 class="text-white text-lg font-bold drop-shadow-lg">{project.title}</h3>
              <a
                href={`#project-${i}`}
                class="text-white text-sm font-medium bg-white/20 hover:bg-white/30 px-3 py-1.5 rounded-lg transition-colors"
              >
                Ver fotos
              </a>
            </figcaption>
          </figure>

          <!-- Bottom: secondary images + name -->
          <footer class="flex gap-3 p-4 items-center">
            <div class="flex gap-2 flex-1">
              <Image
                src={project.images[1].src}
                alt={project.images[1].alt}
                class="w-24 h-16 object-cover rounded-lg transition-all duration-300 group-hover:shadow-md"
              />
              <Image
                src={project.images[2].src}
                alt={project.images[2].alt}
                class="w-24 h-16 object-cover rounded-lg transition-all duration-300 group-hover:shadow-md"
              />
            </div>
            <div class="flex items-center gap-2 text-gray-700 font-medium text-sm shrink-0">
              <span class="w-1.5 h-1.5 rounded-full bg-[#004ea9]" />
              {project.name}
            </div>
          </footer>
        </article>
      ))
    }
  </div>
</section>

<!-- Modals -->
{
  PROJECTS.map((project, i) => (
    <div id={`project-${i}`} class="modal">
      <div class="modal-overlay">
        <a href="#proyectos" class="modal-close" aria-label="Cerrar">&times;</a>
        <div class="modal-content">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">{project.title}</h3>
          <div class="grid grid-cols-1 gap-4">
            {project.images.map((img) => (
              <Image
                src={img.src}
                alt={img.alt}
                class="w-full rounded-xl object-cover max-h-[70vh]"
              />
            ))}
          </div>
          <p class="text-gray-500 text-sm mt-4">{project.name}</p>
        </div>
      </div>
    </div>
  ))
}

<style>
  .modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }

  .modal:target {
    display: flex;
  }

  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    font-size: 2.5rem;
    line-height: 1;
    color: white;
    text-decoration: none;
    z-index: 10;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .modal-close:hover {
    opacity: 1;
  }

  .modal-content {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    max-width: 800px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    animation: modalIn 0.2s ease-out;
  }

  @keyframes modalIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(10px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
</style>
