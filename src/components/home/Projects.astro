---
import { Image } from "astro:assets";
import { PROJECTS } from "@data/projects";
---

<section
  class="bg-gray-100 flex flex-col items-start justify-start gap-2 w-full min-h-screen px-[5%] py-12 lg:py-[5%]"
>
  <div
    class="flex flex-col lg:flex-row items-start lg:items-end justify-between gap-4 lg:gap-0 w-full mb-4"
  >
    <h1 class="flex flex-col gap-2 text-4xl lg:text-6xl font-black uppercase">
      <span class="text-[#004ea9]">Historias</span>
      <span class="text-gray-900">Destacadas</span>
    </h1>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 w-full mt-4">
    {
      PROJECTS.map((project) => (
        <div class="group relative flex flex-col bg-white rounded-2xl overflow-hidden border border-black/5 transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_60px_-10px_rgba(0,78,169,0.3)]">
          <!-- Main image -->
          <div class="relative overflow-hidden">
            <Image
              src={project.images[0].src}
              alt={project.images[0].alt}
              class="w-full h-56 object-cover transition-all duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent" />
            <div class="absolute bottom-4 left-4 right-4">
              <span class="text-white text-lg font-bold drop-shadow-lg">{project.title}</span>
            </div>
          </div>

          <!-- Bottom: secondary images + name -->
          <div class="flex gap-3 p-4 items-center">
            <div class="flex gap-2 flex-1">
              <Image
                src={project.images[1].src}
                alt={project.images[1].alt}
                class="w-24 h-16 object-cover rounded-lg transition-all duration-300 group-hover:shadow-md"
              />
              <Image
                src={project.images[2].src}
                alt={project.images[2].alt}
                class="w-24 h-16 object-cover rounded-lg transition-all duration-300 group-hover:shadow-md"
              />
            </div>
            <div class="flex items-center gap-2 text-gray-700 font-medium text-sm shrink-0">
              <span class="w-1.5 h-1.5 rounded-full bg-[#004ea9]" />
              {project.name}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
