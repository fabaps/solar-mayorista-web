---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

import { SOLAR_SOLUTIONS } from "@data/solarSolutions";
import CanadianSolarLogo from "@imgs/logos/canadian-solar.png";
---

<section
  id="soluciones-solares"
  class="bg-gray-200 flex flex-col items-start justify-center gap-2 w-full h-screen min-h-screen px-[5%] py-[5%]"
>
  <h2 class="flex flex-col gap-2 text-4xl lg:text-6xl font-black uppercase">
    <span class="text-[#004ea9]">Soluciones</span>
    <span class="text-gray-900">Solares</span>
  </h2>
  <h2 class="text-lg lg:text-lg">
    ¿Cuál es el proyecto que te está pidiendo tu cliente?
  </h2>

  <div
    class="flex flex-col lg:flex-row gap-2 my-2 w-full"
    id="category-buttons"
  >
    {
      SOLAR_SOLUTIONS.map((item, index) => (
        <button
          type="button"
          data-index={index}
          class="category-btn border border-[#004fa8] text-[#004fa8] rounded-md px-3 py-2 transition-colors hover:bg-[#2066b1] hover:text-white"
        >
          {item.title}
        </button>
      ))
    }
  </div>

  <div
    class="flex items-center justify-center gap-2 w-full mt-4 lg:py-0 lg:flex-1"
    id="products-grid"
  >
    {
      SOLAR_SOLUTIONS.map((category, catIndex) => (
        <div
          class="product-category hidden flex-row overflow-x-auto gap-8 w-full pb-2"
          data-category-index={catIndex}
        >
          {category.products.map((item) => (
            <div class="flex flex-col items-center gap-2 min-w-40 shrink-0">
              <Image
                src={item.img}
                alt={item.alt}
                class={
                  "w-64 h-64 object-cover transition-all duration-300 hover:scale-105"
                }
              />
              <span class="font-semibold text-sm text-center">
                {item.title}
              </span>
            </div>
          ))}
        </div>
      ))
    }
  </div>
</section>

<script>
  document.addEventListener("astro:page-load", initProductTabs);
  document.addEventListener("DOMContentLoaded", initProductTabs);

  function initProductTabs() {
    const buttons = document.querySelectorAll(".category-btn");
    const categories = document.querySelectorAll(".product-category");

    if (!buttons.length || !categories.length) return;

    categories[0].classList.remove("hidden");
    categories[0].classList.add("flex");
    buttons[0].setAttribute("aria-pressed", "true");
    buttons[0].classList.add("bg-[#004fa8]", "text-white");
    buttons[0].classList.remove("border-[#004fa8]", "text-[#004fa8]");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const index = Number(btn.dataset.index);

        categories.forEach((cat, i) => {
          cat.classList.toggle("hidden", i !== index);
          cat.classList.toggle("flex", i === index);
        });

        buttons.forEach((b, i) => {
          const isActive = i === index;
          b.setAttribute("aria-pressed", String(isActive));
          b.classList.toggle("bg-[#004fa8]", isActive);
          b.classList.toggle("text-white", isActive);
          b.classList.toggle("border-[#004fa8]", !isActive);
          b.classList.toggle("text-[#004fa8]", !isActive);
        });
      });
    });
  }
</script>
