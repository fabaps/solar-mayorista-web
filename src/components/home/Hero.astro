---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

import Banner from "@imgs/hero/banner.jpg";

import BottomCards from "./BottomCards.astro";
---

<div
  class="relative flex flex-col items-center justify-center gap-2 w-full h-screen px-[5%]"
>
  <div class="fixed top-0 left-0 w-screen h-screen -z-1">
    <Image
      src={Banner}
      alt="Imagen de fondo"
      class="w-full h-full object-cover mask-b-from-20% mask-b-to-90%"
    />
  </div>

  <div class="flex flex-col gap-2 -translate-y-1/4">
    <div class="group w-full">
      <h1
        class="font-playfair text-6xl text-center border-2 transition-all duration-1000 ease-out group-hover:rotate-x-360"
      >
        TODO LO QUE NECESITAS PARA DESARROLLAR TU PROYECTO DE ENERGÍA SOLAR
      </h1>
    </div>

    <a
      href="/"
      class="group relative flex items-center justify-center gap-2 w-fit bg-black text-white px-3 py-1 text-xl"
    >
      <Icon name="mdi:whatsapp" class="text-xl text-white" />
      <span class="relative"> Contactar </span>

      <span
        class="absolute left-0 bottom-0 h-[2px] w-0 bg-white transition-all duration-300 ease-in group-hover:w-full"
      ></span>
    </a>
  </div>

  <BottomCards />
</div>
