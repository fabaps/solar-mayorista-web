---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

import Banner from "@imgs/hero/banner.jpg";
---

<div
  class="col-span-4 relative flex flex-col items-start justify-center gap-2 w-full h-screen pl-[15%] z-6"
>
  <div class="flex flex-col gap-2">
    <div class="group w-full">
      <h1 class="text-5xl w-full py-2 text-start font-bold text-white">
        TODO LO QUE NECESITAS PARA DESARROLLAR TU PROYECTO DE ENERGÍA SOLAR
      </h1>
    </div>

    <a
      href="/"
      class="group relative flex items-center justify-center gap-2 w-fit transition-all bg-white/15 backdrop-blur-sm text-white px-3 py-1 text-xl rounded-md"
    >
      <Icon name="mdi:whatsapp" class="text-xl text-green-400" />
      <span class="relative"> ¡Aplicar Ahora! </span>

      <span
        class="absolute left-0 bottom-0 h-[2px] w-0 bg-white transition-all duration-300 ease-in group-hover:w-full"
      ></span>
    </a>
  </div>
</div>
