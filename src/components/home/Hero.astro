---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

import Banner from "@imgs/hero/banner.jpg";
---

<header
  class="col-span-4 lg:col-span-4 relative flex flex-col items-start justify-center gap-2 w-full h-screen pl-[15%] z-6"
>
  <div class="flex flex-col gap-2">
    <h1
      class="text-5xl w-full py-2 text-start font-bold text-white uppercase"
    >
      El modelo de negocio que necesitas para desarrollar tu proyecto de
      energía solar
    </h1>

    <a
      href="/aplica"
      class="group relative flex items-center justify-center gap-2 w-fit transition-all bg-white/15 backdrop-blur-sm text-white px-3 py-1 text-xl rounded-md"
    >
      <span class="relative">Aplica con tu proyecto</span>
      <Icon name="lucide:arrow-right" class="text-xl" />

      <span
        class="absolute left-0 bottom-0 h-[2px] w-0 bg-white transition-all duration-300 ease-in group-hover:w-full"
      ></span>
    </a>
  </div>
</header>
