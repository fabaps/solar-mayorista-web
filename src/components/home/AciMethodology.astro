---
import { ACI_METHODOLOGY_ITEMS } from "@data/aciMethodology";
import { Image } from "astro:assets";
---

<section
  class="bg-[#004ea9] text-white flex flex-col items-center justify-center gap-4 w-full h-screen min-h-screen px-[10%]"
>
  <h1 class="text-[#ffd600] font-black text-6xl text-start w-full">ACI</h1>
  <h2 class="flex gap-2 text-5xl font-black text-start w-full">
    <span><span class="text-[#ffd600]">A</span>dquiere</span>
    <span><span class="text-[#ffd600]">C</span>apacitate</span>
    <span><span class="text-[#ffd600]">I</span>nstala</span>
  </h2>
  <p class="text-xl text-start w-full">
    Metodología comprobada con 10 años de experiencia para que ejecutes tus
    proyectos de energía solar.
  </p>

  <div class="grid grid-cols-2 items-start justify-center gap-2 w-full">
    <div
      class="group flex flex-col items-start justify-center bg-white/5 border border-white/15 px-6 py-4 w-full"
    >
      <span class="font-bold">
        <span class="bg-white px-2 rounded-full text-[#0d58ac] mr-1">1</span>
        Para instalar plantas solares a tus clientes potenciales
      </span>
      <span>Capacita a tu equipo técnico y ejecutua tus propios proyectos.</span
      >
    </div>

    <div
      class="group flex flex-col items-start justify-center bg-white/5 border border-white/15 px-6 py-4 w-full"
    >
      <span class="font-bold">
        <span class="bg-white px-1.5 rounded-full text-[#0d58ac] mr-1">2</span>
        Para instalar una planta solar en tu empresa
      </span>
      <span>
        Capacita a tu equipo técnico, optimiza recursos y
        <strong> reduce un 25% </strong>
        tu inversión inicial.
      </span>
    </div>
  </div>

  <div class="grid grid-cols-3 items-center justify-center gap-2 w-full h-auto">
    {
      ACI_METHODOLOGY_ITEMS.map((item) => (
        <div class="flex flex-col">
          <Image
            src={item.img}
            alt={item.title}
            class={"w-full h-64 object-cover"}
          />
          <span class="bg-white/5 border border-white/15 w-full text-center font-bold">
            {item.title}
          </span>
        </div>
      ))
    }
  </div>
</section>
