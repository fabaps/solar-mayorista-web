---
import { METHODOLOGY_STEPS } from "@data/methodologySteps.ts";
import { ACI_METHODOLOGY_ITEMS } from "@data/aciMethodology";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import BgParallaxImg from "@imgs/home/estadisticas/fondo.jpg";
---

<section
  id="capacitacion"
  class="relative bg-[#004ea9] text-white w-full px-[5%]"
>
  <Image
    src={BgParallaxImg}
    alt={"Imagen de fondo de un parque solar"}
    data-speed={0.2}
    class="effect-parallax-image absolute -top-1/1 left-0 w-full h-auto grayscale-50 will-change-transform"
  />
  <div
    class="absolute top-0 left-0 w-full h-full bg-radial-[at_50%_75%] from-[#004ea966] from-40% to-[#06183D] backdrop-blur-xs"
  >
  </div>

  <div class="relative py-12">
    <h2
      class="font-black text-4xl lg:text-6xl text-start w-full uppercase text-gray-100"
    >
      Capacitación
    </h2>
    <p class="text-sm lg:text-xl text-start w-full text-gray-200">
      Metodología comprobada con 10 años de experiencia para que ejecutes tus
      proyectos de energía solar.
    </p>

    <div
      class="grid grid-cols-1 lg:grid-cols-2 items-start justify-center gap-2 w-full mt-4"
    >
      {
        METHODOLOGY_STEPS.map((step) => (
          <article class="flex flex-col items-start justify-start bg-linear-to-br from-35% from-black/15 to-white/15 backdrop-blur-sm border border-white/15 px-6 py-4 w-full min-h-full">
            <h3 class="font-bold flex items-center gap-2 mb-2">
              <Icon name={step.icon} class="text-2xl shrink-0" />
              {step.title}
            </h3>
            <p set:html={step.description} />
          </article>
        ))
      }
    </div>

    <ul class="grid grid-cols-3 gap-2 w-full h-auto list-none mt-4">
      {
        ACI_METHODOLOGY_ITEMS.map((item) => (
          <li class="bg-black/10 backdrop-blur-lg border border-white/15 w-full text-center font-bold">
            {item.title}
          </li>
        ))
      }
    </ul>
  </div>
</section>
