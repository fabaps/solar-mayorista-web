---
import { Icon } from "astro-icon/components";
import { SUPPORT_PLANS } from "@data/technicalSupport";
---

<section
  id="soporte-tecnico"
  class="bg-gray-200 flex flex-col items-start justify-center gap-2 w-full min-h-screen px-[5%] py-12 lg:py-[5%]"
>
  <header>
    <h2 class="flex flex-col gap-2 text-4xl lg:text-6xl font-black uppercase">
      <span class="text-[#004fa8]">Soporte Técnico</span>
      <span class="text-gray-900">Post Venta</span>
    </h2>
    <p class="w-full lg:w-3/4 text-sm lg:text-xl mb-4">
      Nuestro equipo de expertos está listo para brindarte el mejor
      acompañamiento y asegurar el éxito de tus proyectos solares.
    </p>
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 w-full">
    {
      SUPPORT_PLANS.map((plan) => (
        <article
          class={`flex flex-col gap-2 rounded-xl p-6 transition-all duration-300 ${
            plan.type === "premium"
              ? "bg-[#004ea9] text-white"
              : "bg-white text-gray-900"
          }`}
        >
          <header class="flex items-center gap-3">
            <div
              class={`flex items-center justify-center w-10 h-10 rounded-lg ${
                plan.type === "premium" ? "bg-white/15" : "bg-[#004ea9]/10"
              }`}
            >
              <Icon
                name={
                  plan.type === "premium" ? "lucide:crown" : "lucide:shield"
                }
                class={`text-xl ${plan.type === "premium" ? "text-white" : "text-[#004ea9]"}`}
              />
            </div>
            <h3 class="font-bold text-xl">{plan.title}</h3>
          </header>

          <p
            class={`text-sm rounded-lg px-3 py-2 ${
              plan.type === "premium"
                ? "bg-white/10 text-gray-100"
                : "bg-[#004ea9]/5 text-[#004ea9] font-medium"
            }`}
          >
            {plan.subtitle}
          </p>

          <ul class="flex flex-col gap-2.5 mt-2">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-2 text-sm">
                <Icon
                  name="lucide:circle"
                  class={`mt-0.5 shrink-0 text-[8px] ${plan.type === "premium" ? "text-white/70" : "text-[#004ea9]/60"}`}
                />
                <span
                  class={
                    plan.type === "premium" ? "text-gray-100" : "text-gray-600"
                  }
                >
                  {feature}
                </span>
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>

  <div class="flex items-center justify-center w-full mt-6">
    <a
      href="/aplica"
      class="group flex items-center gap-2 hover:underline w-fit px-5 py-2 rounded-md"
    >
      <Icon name="lucide:notepad-text" class="text-2xl text-[#004fa8]" />
      <span>Aplica con tu proyecto</span>
      <Icon
        name="lucide:arrow-right"
        class="group-hover:translate-x-2 transition-all duration-500"
      />
    </a>
  </div>
</section>
