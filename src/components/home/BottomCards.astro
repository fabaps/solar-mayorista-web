---
import { PILLARS } from "@data/pillars";
---

<div
  class="hidden absolute bottom-4 right-0 lg:grid grid-rows-5 px-4 w-fit overflow-hidden gap-2 transition-all duration-500 ease-in-out cursor-pointer z-10"
>
  {
    PILLARS.map((pillar) => (
      <div class="group relative flex">
        <a
          href={pillar.url}
          class="text-nowrap truncate text-center text-white bg-black/50 backdrop-blur-xl px-4 py-4 rounded-md group-hover:underline w-full text-bold"
        >
          {pillar.titlePreview}
        </a>
      </div>
    ))
  }
</div>
