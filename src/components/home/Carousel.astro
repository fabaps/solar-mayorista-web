---
import { Image } from "astro:assets";
import Img1 from "@imgs/home/carousel/img-1.webp";
import Img2 from "@imgs/home/carousel/img-2.webp";
import Img3 from "@imgs/home/carousel/img-3.webp";
import Img4 from "@imgs/home/carousel/img-7.webp";
import Img5 from "@imgs/home/carousel/img-10.webp";
import Img6 from "@imgs/home/carousel/img-6.webp";

interface Props {
  hidden?: string;
}

const { hidden = "" } = Astro.props;

const TOP_IMAGES = [
  { src: Img1, alt: "Parque Solar" },
  { src: Img2, alt: "Montacargas cargando contenedores con paneles solares" },
  { src: Img3, alt: "Técnico instalador solar" },
];

const BOTTOM_IMAGES = [
  { src: Img4, alt: "Parque solar en desarrollo" },
  { src: Img5, alt: "Camiones con contenedores que llevan paneles solares" },
  { src: Img6, alt: "Personas instaladoras de paneles solares" },
];
---

<section
  class={`${hidden} relative col-span-8 lg:col-span-8 bg-[#06183D] flex flex-col gap-0.5 overflow-hidden w-full min-h-screen max-h-screen z-1`}
>
  <div
    class="absolute top-0 left-0 w-full h-full bg-linear-to-r from-black via-black/5 to-inherit z-9"
  >
  </div>

  <!-- TOP CAROUSEL -->
  <div class="carousel-hero">
    <div class="group-carousel group-carousel-top">
      {
        TOP_IMAGES.map((img) => (
          <Image
            src={img.src}
            alt={img.alt}
            loading={"lazy"}
            fetchpriority={"auto"}
            decoding="async"
          />
        ))
      }
    </div>
    <div class="group-carousel group-carousel-top" aria-hidden="true">
      {
        TOP_IMAGES.map((img) => (
          <Image
            src={img.src}
            alt={img.alt}
            loading={"lazy"}
            fetchpriority={"auto"}
            decoding="async"
          />
        ))
      }
    </div>
  </div>

  <!-- BOTTOM CAROUSEL -->
  <div class="carousel-hero">
    <div class="group-carousel group-carousel-bottom">
      {
        BOTTOM_IMAGES.map((img) => (
          <Image
            src={img.src}
            alt={img.alt}
            loading={"lazy"}
            fetchpriority={"auto"}
            decoding="async"
          />
        ))
      }
    </div>
    <div class="group-carousel group-carousel-bottom" aria-hidden="true">
      {
        BOTTOM_IMAGES.map((img) => (
          <Image
            src={img.src}
            alt={img.alt}
            loading={"lazy"}
            fetchpriority={"auto"}
            decoding="async"
          />
        ))
      }
    </div>
  </div>
</section>
